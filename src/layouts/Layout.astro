---
import '../styles/global.css';

import { getLangFromUrl } from '../i18n/translations';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: string;
	publishDate?: string;
	tags?: string[];
}

const SITE_URL = 'https://ardilacesar.com';
const SITE_NAME = 'cesar.ships';
const DEFAULT_DESCRIPTION = 'Product Engineer, Digital Artisan & Strategist. 25 years of shipping value.';
const DEFAULT_IMAGE = '/og-default.png';

const {
	title,
	description = DEFAULT_DESCRIPTION,
	image,
	type = 'website',
	publishDate,
	tags,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const ogImage = image ? (image.startsWith('http') ? image : `${SITE_URL}${image}`) : `${SITE_URL}${DEFAULT_IMAGE}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang={lang}
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta -->
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		{tags && tags.length > 0 && (
			<meta name="keywords" content={tags.join(', ')} />
		)}

		<!-- Open Graph -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content={ogImage.endsWith('.png') ? 'image/png' : 'image/jpeg'} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content="en_US" />

		{type === 'article' && publishDate && (
			<meta property="article:published_time" content={publishDate} />
		)}
		{type === 'article' && (
			<meta property="article:author" content="Cesar Ardila" />
		)}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@CesarArdilaB" />
		<meta name="twitter:creator" content="@CesarArdilaB" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-J9VVKQ3W73"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-J9VVKQ3W73');
		</script>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-brand-dark text-brand-light font-sans antialiased selection:bg-brand-accent selection:text-brand-dark">
		<!-- Transition overlay -->
		<div id="page-transition" class="page-transition"></div>

		<div id="page-content" class="page-content">
			<slot />
		</div>

		<script is:inline>
			(function() {
				// Random accent color + matching favicon and logo
				var palette = [
					{ hex: '#ff4500', slug: 'orange' },
					{ hex: '#00ff88', slug: 'green' },
					{ hex: '#ff006e', slug: 'pink' },
					{ hex: '#00d4ff', slug: 'cyan' },
					{ hex: '#bf5af2', slug: 'purple' },
					{ hex: '#ffcc00', slug: 'yellow' },
					{ hex: '#ff3366', slug: 'redpink' },
					{ hex: '#39ff14', slug: 'lime' },
				];
				var pick = palette[Math.floor(Math.random() * palette.length)];
				document.documentElement.style.setProperty('--color-brand-accent', pick.hex);
				var favicon = document.querySelector('link[rel="icon"]');
				if (favicon) favicon.setAttribute('href', '/favicon/favicon-' + pick.slug + '.svg');
				var logo = document.getElementById('brand-logo');
				if (logo) logo.setAttribute('src', '/logo/logo-' + pick.slug + '.svg');

				// Page enter animation
				var content = document.getElementById('page-content');
				content.classList.add('entered');

				// Intercept internal link clicks for exit transition
				document.addEventListener('click', function(e) {
					var link = e.target.closest('a');
					if (!link) return;
					var href = link.getAttribute('href');
					if (!href) return;

					// Skip external links, anchors, and special links
					if (href.startsWith('http') || href.startsWith('#') || href.startsWith('mailto:') || link.target === '_blank') return;

					e.preventDefault();
					var overlay = document.getElementById('page-transition');
					content.classList.add('exiting');
					overlay.classList.add('active');

					setTimeout(function() {
						window.location.href = href;
					}, 350);
				});
			})();
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
                overscroll-behavior: none;
	}

	/* Page transition overlay */
	.page-transition {
		position: fixed;
		inset: 0;
		z-index: 9999;
		pointer-events: none;
		background: #050505;
		opacity: 0;
		transition: opacity 0.3s ease-out;
	}

	.page-transition.active {
		opacity: 1;
		pointer-events: all;
	}

	/* Scan lines on the overlay */
	.page-transition.active::after {
		content: '';
		position: absolute;
		inset: 0;
		background: repeating-linear-gradient(
			0deg,
			transparent,
			transparent 2px,
			rgba(255, 255, 255, 0.02) 2px,
			rgba(255, 255, 255, 0.02) 4px
		);
		animation: scan-down 0.3s linear;
	}

	@keyframes scan-down {
		from { transform: translateY(-100%); }
		to { transform: translateY(0); }
	}

	/* Page content enter/exit */
	.page-content {
		opacity: 0;
		transform: translateY(8px);
		transition: opacity 0.4s ease-out, transform 0.4s ease-out;
	}

	.page-content.entered {
		opacity: 1;
		transform: translateY(0);
	}

	.page-content.exiting {
		opacity: 0;
		transform: translateY(-8px);
		transition: opacity 0.25s ease-in, transform 0.25s ease-in;
	}
</style>
