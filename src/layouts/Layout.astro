---
import '../styles/global.css';

import { getLangFromUrl } from '../i18n/translations';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: string;
	publishDate?: string;
	tags?: string[];
}

const SITE_URL = 'https://ardilacesar.com';
const SITE_NAME = 'cesar.ships';
const DEFAULT_DESCRIPTION = 'Product Engineer, Digital Artisan & Strategist. 25 years of shipping value.';
const DEFAULT_IMAGE = '/og-default.png';

const {
	title,
	description = DEFAULT_DESCRIPTION,
	image,
	type = 'website',
	publishDate,
	tags,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const ogImage = image ? (image.startsWith('http') ? image : `${SITE_URL}${image}`) : `${SITE_URL}${DEFAULT_IMAGE}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang={lang}
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta -->
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		{tags && tags.length > 0 && (
			<meta name="keywords" content={tags.join(', ')} />
		)}

		<!-- Open Graph -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content={ogImage.endsWith('.png') ? 'image/png' : 'image/jpeg'} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content="en_US" />

		{type === 'article' && publishDate && (
			<meta property="article:published_time" content={publishDate} />
		)}
		{type === 'article' && (
			<meta property="article:author" content="Cesar Ardila" />
		)}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@CesarArdilaB" />
		<meta name="twitter:creator" content="@CesarArdilaB" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-J9VVKQ3W73"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-J9VVKQ3W73');
		</script>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-brand-dark text-brand-light font-sans antialiased selection:bg-brand-accent selection:text-brand-dark">
		<slot />
		<script is:inline>
			(function() {
				var colors = [
					'#ff4500', // original orange
					'#00ff88', // neon green
					'#ff006e', // hot pink
					'#00d4ff', // electric cyan
					'#bf5af2', // vivid purple
					'#ffcc00', // glowing yellow
					'#ff3366', // neon red-pink
					'#39ff14', // electric lime
				];
				var pick = colors[Math.floor(Math.random() * colors.length)];
				document.documentElement.style.setProperty('--color-brand-accent', pick);
			})();
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
                overscroll-behavior: none;
	}
</style>
