---
import { languages, getLangFromUrl } from '../i18n/translations';
import { getAlternatePostUrl, getAlternatePageUrl } from '../i18n/slugMap';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const alternateUrl = getAlternatePostUrl(currentPath) || getAlternatePageUrl(currentPath);

function getTargetPath(lang: string) {
  if (lang === currentLang) return currentPath;

  // For pages/posts with custom slug maps
  if (alternateUrl) return alternateUrl;

  // For other pages, toggle /es prefix
  if (lang === 'en') {
    return currentPath.replace(/^\/es/, '') || '/';
  }
  return `/es${currentPath}`;
}
---

<div class="flex gap-1 font-mono text-xs tracking-widest">
  {Object.entries(languages).map(([lang, label]) => (
    <a
      href={getTargetPath(lang)}
      class={`px-2 py-1 transition-colors ${
        lang === currentLang
          ? 'bg-brand-accent text-brand-dark font-bold'
          : 'text-gray-500 hover:text-brand-accent'
      }`}
    >
      {label}
    </a>
  ))}
</div>
