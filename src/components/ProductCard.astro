---
interface Props {
  name: string;
  tagline: string;
  details: string[];
  active?: boolean;
  url?: string;
}

const { name, tagline, details, active = false, url } = Astro.props;
const Tag = url ? 'a' : 'div';
---

<Tag
  href={url}
  target={url ? '_blank' : undefined}
  rel={url ? 'noopener noreferrer' : undefined}
  class="bg-brand-dark p-8 md:p-10 group relative overflow-hidden border-b border-brand-border hover:bg-[#0a0a0a] transition-colors duration-300 block"
>
  <!-- Status -->
  <div class="flex items-center justify-between mb-4">
    {active ? (
      <span class="flex items-center gap-2 font-mono text-xs tracking-widest text-green-500">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse-slow"></span>
        LIVE
      </span>
    ) : (
      <span class="font-mono text-xs tracking-widest text-gray-600">SHIPPED</span>
    )}
    {url && (
      <span class="font-mono text-xs text-gray-600 group-hover:text-brand-accent transition-colors">OPEN &rarr;</span>
    )}
  </div>

  <!-- Product name -->
  <h3 class="font-mono text-2xl md:text-3xl font-bold tracking-tight mb-2 group-hover:text-brand-accent transition-colors duration-300">
    {name}
  </h3>

  <!-- Tagline -->
  <p class="font-sans text-sm text-gray-400 mb-6">{tagline}</p>

  <!-- Details -->
  <ul class="flex flex-col gap-2">
    {details.map((item) => (
      <li class="font-mono text-sm text-gray-500 flex items-start gap-3">
        <span class="text-brand-accent mt-0.5 shrink-0">&gt;</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>

  <!-- Accent bar -->
  <div class="w-full h-1 bg-brand-border group-hover:bg-brand-accent transition-colors duration-300 mt-8"></div>
</Tag>
