---
import { getLangFromUrl } from '../i18n/translations';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  marquee?: string;
}

const lang = getLangFromUrl(Astro.url);
const prefix = lang === 'es' ? '/es' : '';
const currentPath = Astro.url.pathname;
const { marquee } = Astro.props;

const defaultMarquee = 'FORM FOLLOWS FUNCTION /// SHIPPING VALUE /// NO BLOAT /// FORM FOLLOWS FUNCTION /// SHIPPING VALUE /// NO BLOAT /// FORM FOLLOWS FUNCTION /// SHIPPING VALUE /// NO BLOAT ///';
const marqueeText = marquee || defaultMarquee;

const links = [
  { href: `${prefix}/`, label: 'HOME' },
  { href: `${prefix}/shipped`, label: 'SHIPPED' },
  { href: '/contact', label: 'CONTACT' },
];

function isActive(href: string) {
  const clean = currentPath.replace(/\/$/, '') || '/';
  const cleanHref = href.replace(/\/$/, '') || '/';
  return clean === cleanHref;
}
---

<div class="col-span-1 md:col-span-12 bg-brand-dark border-b border-brand-border">
  <!-- Top bar: logo + nav + hamburger -->
  <nav class="flex items-center justify-between p-4 md:px-6">
    <a href={`${prefix}/`} class="flex items-center gap-3 group">
      <img src="/logo_barras.png" alt="cesar.ships Logo" class="h-10 w-auto" />
      <span class="font-mono text-lg tracking-tighter font-bold bg-brand-accent text-brand-dark px-1">cesar.ships</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      {links.map((link) => (
        <a
          href={link.href}
          class={`font-mono text-xs tracking-widest transition-colors ${
            isActive(link.href)
              ? 'text-brand-accent'
              : 'text-gray-500 hover:text-brand-accent'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="w-px h-4 bg-brand-border"></div>
      <LanguageSwitcher />
    </div>

    <button id="nav-toggle" class="md:hidden font-mono text-brand-accent text-lg p-1" aria-label="Menu">
      <span id="nav-icon">///</span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden md:hidden border-t border-brand-border">
    {links.map((link) => (
      <a
        href={link.href}
        class={`block px-6 py-3 font-mono text-sm tracking-widest border-b border-brand-border transition-colors ${
          isActive(link.href)
            ? 'text-brand-accent bg-[#0a0a0a]'
            : 'text-gray-500 hover:text-brand-accent hover:bg-[#0a0a0a]'
        }`}
      >
        <span class="text-brand-accent mr-2">&gt;</span>{link.label}
      </a>
    ))}
    <div class="px-6 py-3 flex items-center gap-2">
      <span class="font-mono text-xs text-gray-600 tracking-widest">LANG:</span>
      <LanguageSwitcher />
    </div>
  </div>

  <!-- Marquee -->
  <div class="border-t border-brand-border flex items-center overflow-hidden relative">
    <div class="animate-marquee whitespace-nowrap font-mono text-xs md:text-sm tracking-widest text-brand-light/80 py-3">
      {marqueeText}
    </div>
    <div class="absolute top-0 right-0 h-full w-24 bg-linear-to-l from-brand-dark to-transparent z-10"></div>
    <div class="absolute top-0 left-0 h-full w-24 bg-linear-to-r from-brand-dark to-transparent z-10"></div>
  </div>
</div>

<script is:inline>
  (function() {
    var toggle = document.getElementById('nav-toggle');
    if (!toggle) return;
    toggle.addEventListener('click', function() {
      var menu = document.getElementById('nav-mobile');
      var icon = document.getElementById('nav-icon');
      var open = menu.classList.toggle('hidden');
      icon.textContent = open ? '///' : 'X';
    });
  })();
</script>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }
</style>
