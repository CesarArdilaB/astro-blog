---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'post'>;
	lang?: string;
}

const { post, lang } = Astro.props;
const prefix = lang && lang !== 'en' ? `/${lang}` : '';
---

<a href={`${prefix}/post/${post.slug}`} class="bg-brand-dark p-8 group relative overflow-hidden h-72 flex flex-col justify-between border-r border-brand-border md:last:border-r-0 transition-colors duration-300 hover:bg-[#0a0a0a]">
	<div>
		<span class="font-mono text-xs text-gray-500 group-hover:text-brand-accent transition-colors duration-300">{post.data.publishDate?.toISOString().split('T')[0].replace(/-/g, '.')}</span>
		<h4 class="font-mono text-xl md:text-2xl font-bold group-hover:text-brand-light transition-colors duration-300 line-clamp-3 mt-3">
			{post.data.title}
		</h4>
	</div>
	<div>
		<span class="font-mono text-xs tracking-widest text-gray-600 group-hover:text-brand-accent transition-colors duration-300">
			READ_TRANSMISSION &rarr;
		</span>
		<div class="w-full h-1 bg-brand-border group-hover:bg-brand-accent transition-colors duration-300 mt-3"></div>
	</div>
</a>
