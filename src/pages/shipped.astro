---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Layout
  title="Shipped"
  description="Products I've built and shipped. From autonomous delivery robots to ERPs, crowdfunding platforms, and real-time systems."
>
  <main class="min-h-screen grid grid-cols-1 md:grid-cols-12 gap-px bg-brand-border border border-brand-border">

    <!-- Header -->
    <div class="col-span-1 md:col-span-3 bg-brand-dark text-brand-light p-6 flex items-center justify-between group border-b md:border-b-0 border-brand-border">
      <a href="/"><img src="/logo_barras.png" alt="cesar.ships Logo" class="h-12 w-auto" /></a>
      <div class="flex items-center gap-3">
        <LanguageSwitcher />
        <a href="/" class="font-mono text-xl tracking-tighter font-bold bg-brand-accent text-brand-dark px-1">cesar.ships</a>
      </div>
    </div>

    <!-- Marquee -->
    <div class="col-span-1 md:col-span-9 bg-brand-dark flex items-center overflow-hidden relative border-l-0 md:border-l border-brand-border">
      <div class="animate-marquee whitespace-nowrap font-mono text-xs md:text-sm tracking-widest text-brand-light/80 py-6">
        SHIPPED /// DEPLOYED /// DELIVERED /// SHIPPED /// DEPLOYED /// DELIVERED /// SHIPPED /// DEPLOYED /// DELIVERED ///
      </div>
      <div class="absolute top-0 right-0 h-full w-24 bg-linear-to-l from-brand-dark to-transparent z-10"></div>
      <div class="absolute top-0 left-0 h-full w-24 bg-linear-to-r from-brand-dark to-transparent z-10"></div>
    </div>

    <!-- Hero -->
    <div class="col-span-1 md:col-span-12 bg-brand-dark text-brand-light p-12 md:p-24 flex flex-col justify-center border-t border-brand-border relative overflow-hidden">
      <h1 class="font-mono text-5xl md:text-8xl font-bold tracking-tighter leading-none glitch-text mb-4" data-text="PRODUCTS SHIPPED.">
        PRODUCTS SHIPPED.
      </h1>
      <p class="font-sans text-xl md:text-2xl text-gray-400 max-w-2xl">
        15 years building products that reach real users. <span class="text-brand-accent">These are some of them.</span>
      </p>
      <div class="absolute top-0 right-0 w-1/3 h-full opacity-10 pointer-events-none"
        style="background-image: radial-gradient(#333 1px, transparent 1px); background-size: 20px 20px;">
      </div>
    </div>

    <!-- Product Catalog -->
    <div class="col-span-1 md:col-span-12 bg-brand-dark border-t border-brand-border">
      <div class="p-6 border-b border-brand-border flex items-center gap-4">
        <div class="w-3 h-3 bg-brand-accent"></div>
        <h2 class="font-mono text-lg tracking-widest">PRODUCT_CATALOG</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-brand-border">

        <ProductCard
          name="Kiwibot Operations Platform"
          tagline="Autonomous delivery robot orchestration powering multi-city operations."
          url="https://www.kiwibot.com"
          active={true}
          details={[
            "Logistics platform for autonomous delivery robots",
            "AI-augmented ecosystem with high-level autonomy",
            "Multi-city and campus operations",
            "Cybersecurity posture and ISO 27001 compliance",
            "Automation-first architecture for fully autonomous operation",
          ]}
        />

        <ProductCard
          name="Kiwibot Auto-Assigner v2"
          tagline="Real-time order assignment engine for robot fleet optimization."
          active={true}
          details={[
            "Designed and built the v2 from scratch",
            "Optimizes robot-to-order allocation in real time",
            "Scaled across multiple campuses and cities",
          ]}
        />

        <ProductCard
          name="Kiwibot Real-Time System"
          tagline="WebSocket-powered operations dashboard for live fleet monitoring."
          active={true}
          details={[
            "Real-time data with web sockets",
            "Built v1 alongside product team",
            "Live fleet status, telemetry, and alerts",
          ]}
        />

        <ProductCard
          name="Vaki"
          tagline="Latin American crowdfunding platform connecting creators with backers."
          url="https://vaki.co"
          details={[
            "Iterated the platform with new features",
            "Technical support for customer-facing issues",
            "Proposed and shipped product improvements",
          ]}
        />

        <ProductCard
          name="Native"
          tagline="Platform built from scratch with Flutter. Co-founded and led as CEO."
          details={[
            "Developed the entire platform from zero",
            "Flutter-based mobile and web experience",
            "User acquisition and continuous iteration",
            "Learned business, investments, and new frameworks in the process",
          ]}
        />

        <ProductCard
          name="ERP for Construction"
          tagline="Enterprise resource planning system built for the Colombian construction industry."
          details={[
            "Built from scratch for ParaSuEmpresa",
            "End-to-end ERP covering the construction lifecycle",
            "Custom-tailored for Colombian industry regulations",
          ]}
        />

        <ProductCard
          name="Biospifar Commercial System"
          tagline="Commercial management platform for a pharmaceutical laboratory."
          details={[
            "Built for Biospifar lab in Colombia",
            "Sales, inventory, and commercial operations",
          ]}
        />

        <ProductCard
          name="Cruz Verde Inventory System"
          tagline="Inventory counting system for one of Colombia's largest pharmacy chains."
          details={[
            "Built for Cruz Verde pharmacy chain",
            "Streamlined inventory counting operations",
          ]}
        />

        <ProductCard
          name="Merck Solutions"
          tagline="Custom software solutions for Merck pharmaceutical."
          details={[
            "Freelance engineering engagement",
            "Enterprise-grade solutions",
          ]}
        />

        <ProductCard
          name="Brightstar Solutions"
          tagline="Custom software solutions for Brightstar mobile distribution."
          details={[
            "Freelance engineering engagement",
            "Distribution and logistics tooling",
          ]}
        />

      </div>
    </div>

    <Footer />
  </main>
</Layout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }

  .glitch-text { position: relative; }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #050505;
  }
  .glitch-text::before {
    left: 2px;
    text-shadow: -1px 0 #ff00c1;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim 5s infinite linear alternate-reverse;
  }
  .glitch-text::after {
    left: -2px;
    text-shadow: -1px 0 #00fff9;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim2 5s infinite linear alternate-reverse;
  }
  @keyframes glitch-anim {
    0% { clip: rect(38px, 9999px, 83px, 0); }
    20% { clip: rect(7px, 9999px, 86px, 0); }
    40% { clip: rect(54px, 9999px, 14px, 0); }
    60% { clip: rect(2px, 9999px, 3px, 0); }
    80% { clip: rect(28px, 9999px, 96px, 0); }
    100% { clip: rect(81px, 9999px, 4px, 0); }
  }
  @keyframes glitch-anim2 {
    0% { clip: rect(52px, 9999px, 20px, 0); }
    20% { clip: rect(98px, 9999px, 6px, 0); }
    40% { clip: rect(13px, 9999px, 89px, 0); }
    60% { clip: rect(79px, 9999px, 26px, 0); }
    80% { clip: rect(41px, 9999px, 1px, 0); }
    100% { clip: rect(4px, 9999px, 78px, 0); }
  }
</style>
