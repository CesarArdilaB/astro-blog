---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const BREVO_API_KEY = import.meta.env.PUBLIC_BREVO_API_KEY || '';
---

<Layout
	title="Contact"
	description="Got a question, idea, or just want to say hi? Send a transmission."
>
	<main class="min-h-screen grid grid-cols-1 md:grid-cols-12 gap-px bg-brand-border border border-brand-border">

		<!-- Header -->
		<div class="col-span-1 md:col-span-12 bg-brand-dark p-6 border-b border-brand-border flex items-center justify-between">
			<a href="/" class="font-mono text-sm text-gray-500 hover:text-brand-accent transition-colors">
				<span class="mr-2">&larr;</span> RETURN_TO_BASE
			</a>
			<span class="font-mono text-xl tracking-tighter font-bold bg-brand-accent text-brand-dark px-1">cesar.ships</span>
		</div>

		<!-- Contact Form -->
		<div class="col-span-1 md:col-span-12 bg-brand-dark p-12 md:p-24">
			<div class="max-w-2xl mx-auto">
				<div class="flex items-center gap-3 mb-4">
					<div class="w-3 h-3 bg-brand-accent"></div>
					<h1 class="font-mono text-lg tracking-widest uppercase">OPEN_CHANNEL</h1>
				</div>
				<p class="font-sans text-gray-400 mb-12">
					Got a question, idea, or just want to say hi? Send a transmission.
				</p>

				<form id="contact-form" class="flex flex-col gap-6">
					<div class="flex flex-col gap-2">
						<label for="contact-name" class="font-mono text-xs tracking-widest text-gray-500 uppercase">Name</label>
						<input
							type="text"
							id="contact-name"
							name="sender_name"
							required
							minlength="2"
							maxlength="100"
							autocomplete="name"
							placeholder="Your name"
							class="bg-[#0a0a0a] border border-brand-border text-brand-light px-4 py-3 text-sm font-mono tracking-wide placeholder:text-gray-600 focus:outline-none focus:border-brand-accent invalid:border-red-500"
						/>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-email" class="font-mono text-xs tracking-widest text-gray-500 uppercase">Email</label>
						<input
							type="email"
							id="contact-email"
							name="email"
							required
							autocomplete="email"
							pattern="[^@\s]+@[^@\s]+\.[^@\s]+"
							placeholder="your@email.com"
							class="bg-[#0a0a0a] border border-brand-border text-brand-light px-4 py-3 text-sm font-mono tracking-wide placeholder:text-gray-600 focus:outline-none focus:border-brand-accent invalid:border-red-500"
						/>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-subject" class="font-mono text-xs tracking-widest text-gray-500 uppercase">Subject</label>
						<input
							type="text"
							id="contact-subject"
							name="subject"
							required
							minlength="3"
							maxlength="200"
							placeholder="What's this about?"
							class="bg-[#0a0a0a] border border-brand-border text-brand-light px-4 py-3 text-sm font-mono tracking-wide placeholder:text-gray-600 focus:outline-none focus:border-brand-accent invalid:border-red-500"
						/>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-message" class="font-mono text-xs tracking-widest text-gray-500 uppercase">Message</label>
						<textarea
							id="contact-message"
							name="message"
							required
							minlength="10"
							maxlength="5000"
							rows="6"
							placeholder="Your message..."
							class="bg-[#0a0a0a] border border-brand-border text-brand-light px-4 py-3 text-sm font-mono tracking-wide placeholder:text-gray-600 focus:outline-none focus:border-brand-accent invalid:border-red-500 resize-none"
						></textarea>
					</div>

					<button
						type="submit"
						class="bg-brand-accent text-brand-dark px-6 py-3 text-sm font-mono font-bold tracking-widest uppercase hover:bg-orange-600 transition-colors self-start"
					>
						SEND_TRANSMISSION
					</button>
				</form>

				<p id="contact-msg" class="mt-6 text-sm font-mono tracking-wide hidden"></p>
			</div>
		</div>

		<Footer />
	</main>
</Layout>

<script define:vars={{ BREVO_API_KEY }}>
	function sanitize(str) {
		var el = document.createElement('div');
		el.textContent = str;
		return el.innerHTML;
	}

	document.getElementById('contact-form').addEventListener('submit', async (e) => {
		e.preventDefault();
		var form = e.target;
		var msg = document.getElementById('contact-msg');
		var btn = form.querySelector('button');
		var name = form.sender_name.value.trim();
		var email = form.email.value.trim();
		var subject = form.subject.value.trim();
		var message = form.message.value.trim();

		// Client-side validation
		var errors = [];
		if (name.length < 2) errors.push('Name must be at least 2 characters.');
		if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) errors.push('Please enter a valid email.');
		if (subject.length < 3) errors.push('Subject must be at least 3 characters.');
		if (message.length < 10) errors.push('Message must be at least 10 characters.');

		if (errors.length > 0) {
			msg.textContent = '/// ' + errors[0].toUpperCase();
			msg.className = 'mt-6 text-sm font-mono tracking-wide text-red-500';
			return;
		}

		btn.textContent = 'TRANSMITTING...';
		btn.disabled = true;
		btn.classList.add('opacity-50', 'cursor-not-allowed');

		try {
			var safeName = sanitize(name);
			var safeEmail = sanitize(email);
			var safeSubject = sanitize(subject);
			var safeMessage = sanitize(message).replace(/\n/g, '<br>');

			// Add contact to Brevo list #1 (contact form)
			await fetch('https://api.brevo.com/v3/contacts', {
				method: 'POST',
				headers: {
					'api-key': BREVO_API_KEY,
					'Content-Type': 'application/json',
					'Accept': 'application/json',
				},
				body: JSON.stringify({
					email: email,
					listIds: [1],
					updateEnabled: true,
					attributes: { FIRSTNAME: name },
				}),
			});

			// Send transactional email
			var res = await fetch('https://api.brevo.com/v3/smtp/email', {
				method: 'POST',
				headers: {
					'api-key': BREVO_API_KEY,
					'Content-Type': 'application/json',
					'Accept': 'application/json',
				},
				body: JSON.stringify({
					sender: {
						name: 'cesar.ships Contact Form',
						email: 'cesar.ardila@gmail.com',
					},
					to: [{
						email: 'cesar.ardila@gmail.com',
						name: 'Cesar Ardila',
					}],
					replyTo: { email: email, name: name },
					subject: '[cesar.ships] ' + subject,
					htmlContent: '<h2>New transmission from ' + safeName + '</h2>' +
						'<p><strong>From:</strong> ' + safeName + ' (' + safeEmail + ')</p>' +
						'<p><strong>Subject:</strong> ' + safeSubject + '</p>' +
						'<hr>' +
						'<p>' + safeMessage + '</p>',
				}),
			});

			if (res.ok) {
				msg.textContent = '/// TRANSMISSION SENT SUCCESSFULLY. I\'LL GET BACK TO YOU.';
				msg.className = 'mt-6 text-sm font-mono tracking-wide text-green-500';
				form.reset();
			} else {
				throw new Error('Failed to send');
			}
		} catch (err) {
			msg.textContent = '/// ERROR: TRANSMISSION FAILED. PLEASE TRY AGAIN.';
			msg.className = 'mt-6 text-sm font-mono tracking-wide text-red-500';
		} finally {
			btn.textContent = 'SEND_TRANSMISSION';
			btn.disabled = false;
			btn.classList.remove('opacity-50', 'cursor-not-allowed');
		}
	});
</script>
